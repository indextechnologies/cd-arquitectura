---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeccionTexto from '../components/SeccionTexto.astro';
import '../styles/main.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>Contacto – CD Arquitectura</title>
  <meta name="description" content="Contacta con CD Arquitectura para tu próximo proyecto de arquitectura, reforma o interiorismo." />
  <meta property="og:title" content="Contacto – CD Arquitectura" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;300;400;600;700;900&display=swap" rel="stylesheet" />
</head>
<body class="bg-black text-white overflow-x-hidden">

  <Header currentPage="/contacto" />

  <!-- HERO -->
  <section class="relative pt-32 pb-16 px-4 overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(#cc0000 1px, transparent 1px), linear-gradient(90deg, #cc0000 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative z-10 max-w-7xl mx-auto text-center">
      <p class="text-red-500 text-xs font-semibold uppercase tracking-widest mb-3 fade-in">Hablemos</p>
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-none mb-6 fade-in-up">
        Con<span class="text-red-600">tacto</span>
      </h1>
      <p class="text-gray-400 text-base sm:text-lg max-w-xl mx-auto fade-in" style="animation-delay: 0.3s;">
        Cuéntanos tu proyecto. Respondemos en menos de 24 horas.
      </p>
    </div>
  </section>

  <!-- CONTENIDO PRINCIPAL -->
  <section class="py-16 md:py-20 px-4">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

      <!-- Info de contacto -->
      <div class="reveal">
        <h2 class="text-2xl font-black text-white mb-8">Información de Contacto</h2>

        <div class="space-y-8">
          <!-- Dirección -->
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded bg-red-700/20 border border-red-700/30 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Dirección</p>
              <p class="text-white text-sm">Teniente López 811</p>
              <p class="text-gray-400 text-sm">Asunción, Paraguay</p>
            </div>
          </div>

          <!-- Teléfonos -->
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded bg-red-700/20 border border-red-700/30 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Teléfonos</p>
              <a href="tel:+595981880177" class="text-white text-sm block hover:text-red-400 transition-colors duration-300">0981 880 177 – Marcello Caffiero</a>
              <a href="tel:+595981256150" class="text-white text-sm block hover:text-red-400 transition-colors duration-300">0981 256 150 – Vanessa Caffiero</a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded bg-red-700/20 border border-red-700/30 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Email</p>
              <a href="mailto:contacto@cdarquitectura.com" class="text-white text-sm hover:text-red-400 transition-colors duration-300">contacto@cdarquitectura.com</a>
            </div>
          </div>

          <!-- Horario -->
          <div class="flex gap-4">
            <div class="w-10 h-10 rounded bg-red-700/20 border border-red-700/30 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-gray-500 text-xs uppercase tracking-wider mb-1">Horario</p>
              <p class="text-white text-sm">Lunes – Viernes: 9:00 – 18:00</p>
              <p class="text-gray-400 text-sm">Sábados: 10:00 – 14:00</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulario -->
      <div class="reveal">
        <h2 class="text-2xl font-black text-white mb-8">Envíanos un Mensaje</h2>

        <form id="contact-form" class="space-y-5" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="text-gray-500 text-xs uppercase tracking-wider block mb-2" for="nombre">Nombre *</label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                placeholder="Tu nombre"
                required
                class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-red-600 transition-colors duration-300"
              />
            </div>
            <div>
              <label class="text-gray-500 text-xs uppercase tracking-wider block mb-2" for="apellido">Apellido</label>
              <input
                id="apellido"
                name="apellido"
                type="text"
                placeholder="Tu apellido"
                class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-red-600 transition-colors duration-300"
              />
            </div>
          </div>

          <div>
            <label class="text-gray-500 text-xs uppercase tracking-wider block mb-2" for="email">Email *</label>
            <input
              id="email"
              name="email"
              type="email"
              placeholder="tu@email.com"
              required
              class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-red-600 transition-colors duration-300"
            />
          </div>

          <div>
            <label class="text-gray-500 text-xs uppercase tracking-wider block mb-2" for="telefono">Teléfono</label>
            <input
              id="telefono"
              name="telefono"
              type="tel"
              placeholder="0981 000 000"
              class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-red-600 transition-colors duration-300"
            />
          </div>

          <div>
            <label class="text-gray-500 text-xs uppercase tracking-wider block mb-2" for="servicio">Tipo de Proyecto</label>
            <select
              id="servicio"
              name="servicio"
              class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-3 text-sm text-gray-300 focus:outline-none focus:border-red-600 transition-colors duration-300"
            >
              <option value="">Selecciona un servicio</option>
              <option value="hogares">Hogares y Reformas</option>
              <option value="comercial">Espacios Comerciales</option>
              <option value="oficinas">Oficinas y Corporativo</option>
              <option value="mantenimiento">Servicios y Mantenimiento</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label class="text-gray-500 text-xs uppercase tracking-wider block mb-2" for="mensaje">Mensaje *</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              placeholder="Cuéntanos sobre tu proyecto..."
              required
              class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-red-600 transition-colors duration-300 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-glow w-full bg-red-700 hover:bg-red-600 text-white font-semibold py-4 rounded text-sm uppercase tracking-wider transition-colors duration-300"
          >
            Enviar Mensaje
          </button>

          <div id="form-success" class="hidden text-center py-4 text-green-400 text-sm">
            Mensaje enviado. Te contactaremos pronto.
          </div>
        </form>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
      { threshold: 0.08 }
    );
    revealEls.forEach(el => observer.observe(el));

    // Form feedback
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const success = document.getElementById('form-success');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      success?.classList.remove('hidden');
      form.reset();
      setTimeout(() => success?.classList.add('hidden'), 5000);
    });
  </script>

</body>
</html>

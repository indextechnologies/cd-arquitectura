---
const year = new Date().getFullYear();
---

<footer class="bg-black border-t border-gray-800 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

      <!-- Logo & tagline -->
      <div>
        <div class="flex items-center gap-0 text-2xl font-black mb-3">
          <span class="neon-cd">CD</span>
          <span class="text-gray-600 font-thin mx-1">_</span>
          <span class="neon-arq text-lg font-light tracking-widest">ARQ</span>
        </div>
        <p class="text-gray-500 text-sm leading-relaxed">
          Arquitectura moderna con visión, precisión y pasión por el detalle.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-white text-xs font-semibold uppercase tracking-widest mb-4">Navegación</h4>
        <ul class="space-y-2">
          {[
            ['/', 'Inicio'],
            ['/portafolio', 'Portafolio'],
            ['/que-hacemos', 'Qué Hacemos'],
            ['/clientes', 'Clientes'],
            ['/contacto', 'Contacto'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="text-gray-500 text-sm hover:text-red-500 transition-colors duration-300">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white text-xs font-semibold uppercase tracking-widest mb-4">Contacto</h4>
        <ul class="space-y-2 text-gray-500 text-sm">
          <li>+34 600 000 000</li>
          <li>+34 610 000 000</li>
          <li>contacto@cdarquitectura.com</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-gray-600 text-xs">&copy; {year} CD Arquitectura. Todos los derechos reservados.</p>
      <p class="text-gray-700 text-xs">Diseño &amp; Desarrollo · Index Technologies</p>
    </div>
  </div>
</footer>
